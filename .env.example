# whistx local config
# 必須
OPENAI_API_KEY=

# 任意
OPENAI_BASE_URL=
WHISPER_MODEL=whisper-1
SUMMARY_API_KEY=
SUMMARY_BASE_URL=
SUMMARY_MODEL=gpt-4o-mini
SUMMARY_TEMPERATURE=0.2
SUMMARY_INPUT_MAX_CHARS=16000
PROOFREAD_API_KEY=
PROOFREAD_BASE_URL=
PROOFREAD_MODEL=gpt-4o-mini
PROOFREAD_TEMPERATURE=0.0
PROOFREAD_INPUT_MAX_CHARS=24000
# UI banners (JSON array). Example:
# UI_BANNERS=[{"id":"notice-1","type":"warning","title":"注意","message":"社外秘情報を入力しないでください","dismissible":true}]
UI_BANNERS=
DIARIZATION_ENABLED=0
# Hugging Face token with read access. Accept gated model terms for:
# pyannote/speaker-diarization-3.1 and pyannote/segmentation-3.0
DIARIZATION_HF_TOKEN=
DIARIZATION_MODEL=pyannote/speaker-diarization-3.1
DIARIZATION_DEVICE=auto
DIARIZATION_SAMPLE_RATE=16000
DIARIZATION_NUM_SPEAKERS=0
DIARIZATION_MIN_SPEAKERS=0
DIARIZATION_MAX_SPEAKERS=0
DIARIZATION_WORK_DIR=data/diarization
DIARIZATION_KEEP_CHUNKS=0
# Optional: set 1 to avoid xet download path issues on some environments
HF_HUB_DISABLE_XET=1
FFMPEG_BIN=ffmpeg
DEFAULT_LANGUAGE=ja
DEFAULT_PROMPT=
DEFAULT_TEMPERATURE=0.0
CONTEXT_PROMPT_ENABLED=1
CONTEXT_MAX_CHARS=1000
MAX_QUEUE_SIZE=8
MAX_CHUNK_BYTES=12582912

# 起動オプション
PORT=8005
HOST=0.0.0.0
APP=server.app:app

# run.sh
SKIP_PIP_INSTALL=0
VENV_DIR=.venv

# start.sh / podman-run.sh
IMAGE_NAME=whistx:latest
CONTAINER_NAME=whistx
DATA_DIR=./data

# podman-run.sh (rootless)
PODMAN_USERNS=keep-id
PODMAN_VOLUME_OPTS=Z
