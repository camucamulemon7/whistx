# whistx configuration
# Canonical naming: ASR_* / APP_* / SUMMARY_* / PROOFREAD_* / DIARIZATION_*

# -----------------------------------------------------------------------------
# ASR (OpenAI-compatible transcription endpoint)
# -----------------------------------------------------------------------------
ASR_API_KEY=
ASR_BASE_URL=
ASR_MODEL=whisper-1
ASR_DEFAULT_LANGUAGE=ja
ASR_DEFAULT_PROMPT=
ASR_DEFAULT_TEMPERATURE=0.0
ASR_PREPROCESS_ENABLED=1
ASR_PREPROCESS_SAMPLE_RATE=16000
ASR_OVERLAP_MS=3500
ASR_CONTEXT_PROMPT_ENABLED=1
ASR_CONTEXT_MAX_CHARS=1000
ASR_CONTEXT_RECENT_LINES=2
ASR_CONTEXT_TERM_LIMIT=48
ASR_MAX_QUEUE_SIZE=8
ASR_MAX_CHUNK_BYTES=12582912

# -----------------------------------------------------------------------------
# Summary (LLM)
# -----------------------------------------------------------------------------
SUMMARY_API_KEY=
SUMMARY_BASE_URL=
SUMMARY_MODEL=gpt-4o-mini
SUMMARY_TEMPERATURE=0.2
SUMMARY_INPUT_MAX_CHARS=16000
# Optional custom prompts
# Placeholders: {text}, {language}
# Built-in default (system):
# SUMMARY_SYSTEM_PROMPT=You are a careful transcription summarizer. Keep factual consistency with the source and do not hallucinate.
# Built-in default (Japanese user prompt):
# SUMMARY_PROMPT_TEMPLATE=以下の文字起こしを日本語で要約してください。\n- 事実に忠実に、推測はしない\n- 重要な決定事項・ToDo・未決事項を箇条書き\n- 最後に1行で全体要旨\n\n文字起こし:\n{text}
# Built-in default (English user prompt):
# SUMMARY_PROMPT_TEMPLATE=Summarize the transcript below in English.\n- Keep key decisions, action items, and open questions.\n- Use concise bullet points.\n- Add a short 1-line conclusion at the end.\n\nTranscript:\n{text}
SUMMARY_SYSTEM_PROMPT=
SUMMARY_PROMPT_TEMPLATE=

# -----------------------------------------------------------------------------
# Proofread (LLM)
# -----------------------------------------------------------------------------
PROOFREAD_API_KEY=
PROOFREAD_BASE_URL=
PROOFREAD_MODEL=gpt-4o-mini
PROOFREAD_TEMPERATURE=0.0
PROOFREAD_INPUT_MAX_CHARS=24000
# Optional custom prompts
# Placeholders: {text}, {language}
# Built-in default (system):
# PROOFREAD_SYSTEM_PROMPT=You are a strict transcript proofreader. Do not add new facts. Preserve meaning, speaker intent, and uncertainty.
# Built-in default (Japanese user prompt):
# PROOFREAD_PROMPT_TEMPLATE=以下は音声認識の文字起こしです。日本語として校正してください。\nルール:\n- 意味は変えない。新しい情報を追加しない。\n- 不自然な繰り返し・誤字・句読点を修正する。\n- 固有名詞は不確実なら無理に変えない。\n- 出力は校正済み本文のみ。説明は不要。\n\n文字起こし:\n{text}
# Built-in default (English user prompt):
# PROOFREAD_PROMPT_TEMPLATE=Proofread the following ASR transcript in English.\nRules:\n- Keep the original meaning and uncertainty.\n- Do not add new facts or inferred content.\n- Fix obvious repetition noise and punctuation/readability.\n- Keep proper nouns as-is when uncertain.\n- Output only the corrected transcript text.\n\nTranscript:\n{text}
PROOFREAD_SYSTEM_PROMPT=
PROOFREAD_PROMPT_TEMPLATE=

# -----------------------------------------------------------------------------
# UI
# -----------------------------------------------------------------------------
# Recommended simple format for Makefile / sed:
#   APP_UI_BANNERS_TEXT=warning|注意|(社外)GPUを使うので社外秘情報を入力しないでください\nよろしくお願いいたします
# Multiple banners:
#   APP_UI_BANNERS_TEXT=warning|注意|本文;;info|補足|録音前に共有音声を確認してください
# Optional 4th field:
#   type|title|message|dismissible
# Default example:
APP_UI_BANNERS_TEXT=warning|注意|(社外)GPUを使うので社外秘情報を入力しないでください\nよろしくお願いいたします
# JSON is still supported via APP_UI_BANNERS if needed.
APP_UI_BANNERS=
APP_BRAND_TITLE=whistx
APP_BRAND_TAGLINE=高精度リアルタイム文字起こし
# Optional prompt template list for the context prompt buttons. Use \n for line breaks.
# Example:
# APP_PROMPT_TEMPLATES=[{"id":"soc","label":"SoC設計","content":"SoC, ASIC, AXI, STA"},{"id":"nand","label":"NAND","content":"NAND, ONFI, LDPC, BBT"}]
APP_PROMPT_TEMPLATES=
# Legacy single-template alias:
# APP_SOC_PROMPT_TEMPLATE=

# -----------------------------------------------------------------------------
# Diarization
# -----------------------------------------------------------------------------
DIARIZATION_ENABLED=0
CONTAINER_INSTALL_DIARIZATION=0
# Hugging Face token with read access. Accept gated model terms for:
# pyannote/speaker-diarization-3.1 and pyannote/segmentation-3.0
DIARIZATION_HF_TOKEN=
DIARIZATION_MODEL=pyannote/speaker-diarization-3.1
DIARIZATION_DEVICE=auto
DIARIZATION_SAMPLE_RATE=16000
DIARIZATION_NUM_SPEAKERS=0
DIARIZATION_MIN_SPEAKERS=0
DIARIZATION_MAX_SPEAKERS=0
DIARIZATION_WORK_DIR=
DIARIZATION_KEEP_CHUNKS=0
DIARIZATION_FFMPEG_BIN=ffmpeg
# Optional: set 1 to avoid xet download path issues on some environments
HF_HUB_DISABLE_XET=1

# -----------------------------------------------------------------------------
# App runtime
# -----------------------------------------------------------------------------
APP_HOST=0.0.0.0
APP_PORT=8005
APP_WS_PATH=/ws/transcribe
APP_ENTRYPOINT=server.app:app
APP_DATA_DIR=./data
# Optional explicit transcript directory. If empty, APP_DATA_DIR/transcripts is used.
APP_TRANSCRIPTS_DIR=

# -----------------------------------------------------------------------------
# Observability (Langfuse)
# -----------------------------------------------------------------------------
LANGFUSE_ENABLED=1
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
LANGFUSE_ENVIRONMENT=
LANGFUSE_RELEASE=
PODMAN_NETWORK=slirp4netns:allow_host_loopback=true

# -----------------------------------------------------------------------------
# Local dev script (run.sh)
# -----------------------------------------------------------------------------
DEV_SKIP_PIP_INSTALL=0
DEV_VENV_DIR=.venv

# -----------------------------------------------------------------------------
# Container scripts (start.sh / podman-run.sh)
# -----------------------------------------------------------------------------
CONTAINER_IMAGE_NAME=whistx:latest
CONTAINER_NAME=whistx
CONTAINER_BUILD_POLICY=missing

# podman-run.sh (rootless)
PODMAN_USERNS=keep-id
PODMAN_VOLUME_OPTS=Z

# -----------------------------------------------------------------------------
# Legacy aliases (backward compatibility)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# WHISPER_MODEL=whisper-1
# HOST=0.0.0.0
# PORT=8005
# WS_PATH=/ws/transcribe
# APP=server.app:app
# DATA_DIR=./data
